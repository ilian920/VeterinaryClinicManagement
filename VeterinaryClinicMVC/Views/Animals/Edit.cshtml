@using VeterinaryClinic.Services.DTOs
@using VeterinaryClinic.Shared.Enums
@model AnimalDto
@{
    ViewData["Title"] = "Редактирай " + Model.Name;
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>Редактирай: @Model.Name</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="OwnerId" value="@Model.OwnerId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Кличка <span class="text-danger">*</span></label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Вид <span class="text-danger">*</span></label>
                            <select name="Species" class="form-select" required>
                                @foreach (var sp in new[] { "Куче", "Котка", "Заек", "Птица", "Влечуго", "Риба", "Друг" })
                                {
                                    <option value="@sp" selected="@(Model.Species == sp)">@sp</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Порода</label>
                            <input type="text" name="Breed" class="form-control" value="@Model.Breed" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Пол <span class="text-danger">*</span></label>
                            <select name="Gender" class="form-select" required>
                                <option value="@((int)AnimalGender.Male)" selected="@(Model.Gender == AnimalGender.Male)">Мъжки</option>
                                <option value="@((int)AnimalGender.Female)" selected="@(Model.Gender == AnimalGender.Female)">Женски</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата на раждане</label>
                            <input type="date" name="DateOfBirth" class="form-control"
                                   value="@(Model.DateOfBirth?.ToString("yyyy-MM-dd"))"
                                   max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Тегло (кг.)</label>
                            <input type="number" name="Weight" class="form-control" step="0.1" min="0" value="@Model.Weight?.ToString("F1")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Цвят на козината</label>
                            <input type="text" name="Color" class="form-control" value="@Model.Color" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Бележки</label>
                            <textarea name="Notes" class="form-control" rows="3">@Model.Notes</textarea>
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази промените
                            </button>
                            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

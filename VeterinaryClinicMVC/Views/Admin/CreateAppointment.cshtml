@using VeterinaryClinic.Services.DTOs
@{
    ViewData["Title"] = "Добави час";
    var vets = ViewBag.Veterinarians as IEnumerable<VeterinarianDto> ?? Enumerable.Empty<VeterinarianDto>();
    var services = ViewBag.Services as IEnumerable<VetServiceDto> ?? Enumerable.Empty<VetServiceDto>();
    var owners = ViewBag.Users as IEnumerable<UserDto> ?? Enumerable.Empty<UserDto>();
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-calendar-plus me-2"></i>Добави час</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Appointments" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="CreateAppointment" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Собственик <span class="text-danger">*</span></label>
                            <select name="OwnerId" class="form-select" required id="ownerSelect">
                                <option value="">-- Изберете собственик --</option>
                                @foreach (var owner in owners)
                                {
                                    <option value="@owner.Id">@owner.FirstName @owner.LastName (@owner.Username)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Животно <span class="text-danger">*</span></label>
                            <select name="AnimalId" class="form-select" required>
                                <option value="">-- Първо изберете собственик --</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ветеринарен лекар <span class="text-danger">*</span></label>
                            <select name="VeterinarianId" class="form-select" required>
                                <option value="">-- Изберете лекар --</option>
                                @foreach (var vet in vets)
                                {
                                    <option value="@vet.Id">Д-р @vet.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Услуга</label>
                            <select name="ServiceId" class="form-select">
                                <option value="">-- Изберете услуга --</option>
                                @foreach (var svc in services)
                                {
                                    <option value="@svc.Id">@svc.Name – @svc.Price.ToString("F2") лв.</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата и час <span class="text-danger">*</span></label>
                            <input type="datetime-local" name="AppointmentDate" class="form-control" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Бележки</label>
                            <textarea name="Notes" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази
                            </button>
                            <a asp-action="Appointments" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

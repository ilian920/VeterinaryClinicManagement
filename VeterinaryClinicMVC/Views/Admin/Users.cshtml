@using VeterinaryClinic.Services.DTOs
@model IEnumerable<UserDto>
@{
    ViewData["Title"] = "Потребители";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-people me-2"></i>Потребители</h1>
    </div>
</div>

<div class="container py-4">
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Потребителско име</th>
                        <th>Имена</th>
                        <th>Имейл</th>
                        <th>Телефон</th>
                        <th>Роля</th>
                        <th>Статус</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in Model)
                    {
                        <tr>
                            <td>@user.Id</td>
                            <td class="fw-bold">@user.Username</td>
                            <td>@user.FirstName @user.LastName</td>
                            <td>@user.Email</td>
                            <td>@(user.Phone ?? "—")</td>
                            <td>
                                @{
                                    var roleBadge = user.Role.ToString() switch {
                                        "Admin" => "danger",
                                        "Veterinarian" => "primary",
                                        _ => "success"
                                    };
                                    var roleName = user.Role.ToString() switch {
                                        "Admin" => "Администратор",
                                        "Veterinarian" => "Лекар",
                                        _ => "Собственик"
                                    };
                                }
                                <span class="badge bg-@roleBadge">@roleName</span>
                            </td>
                            <td>
                                @if (user.IsActive)
                                {
                                    <span class="badge bg-success">Активен</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Неактивен</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="7" class="text-center py-4 text-muted">Няма намерени потребители</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

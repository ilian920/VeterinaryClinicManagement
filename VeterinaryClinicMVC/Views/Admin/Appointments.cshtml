@using VeterinaryClinic.Services.DTOs
@using VeterinaryClinic.Shared.Enums
@model IEnumerable<AppointmentDto>
@{
    ViewData["Title"] = "Всички часове";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-calendar2-check me-2"></i>Записани часове</h1>
        </div>
        <a asp-action="CreateAppointment" class="btn btn-light btn-lg">
            <i class="bi bi-plus-circle me-2"></i>Добави час
        </a>
    </div>
</div>

<div class="container py-4">
    <a asp-action="Dashboard" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
    <div class="card">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Дата и час</th>
                        <th>Животно</th>
                        <th>Собственик</th>
                        <th>Лекар</th>
                        <th>Услуга</th>
                        <th>Статус</th>
                        <th>Действия</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var appt in Model)
                    {
                        <tr>
                            <td>@appt.Id</td>
                            <td>@appt.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="fw-bold">@appt.AnimalName</td>
                            <td>@appt.OwnerName</td>
                            <td>@appt.VeterinarianName</td>
                            <td class="small">@(appt.ServiceName ?? "—")</td>
                            <td>
                                @{
                                    var badge = appt.Status switch {
                                        AppointmentStatus.Scheduled => "primary",
                                        AppointmentStatus.Completed => "success",
                                        AppointmentStatus.Cancelled => "danger",
                                        _ => "secondary"
                                    };
                                    var statusName = appt.Status switch {
                                        AppointmentStatus.Scheduled => "Предстои",
                                        AppointmentStatus.Completed => "Приключен",
                                        AppointmentStatus.Cancelled => "Отказан",
                                        _ => appt.Status.ToString()
                                    };
                                }
                                <span class="badge bg-@badge">@statusName</span>
                            </td>
                            <td>
                                <a asp-action="EditAppointment" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                @if (appt.Status == AppointmentStatus.Scheduled)
                                {
                                    <form asp-action="CancelAppointment" asp-route-id="@appt.Id" method="post" class="d-inline"
                                          onsubmit="return confirm('Отказване на часа?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-x-circle"></i>
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="8" class="text-center py-4 text-muted">Няма намерени часове</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@using VeterinaryClinic.Services.DTOs
@model VeterinarianDto
@{
    ViewData["Title"] = "Добави лекар";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-person-plus me-2"></i>Добави ветеринарен лекар</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Veterinarians" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="CreateVeterinarian" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Име <span class="text-danger">*</span></label>
                            <input type="text" name="FirstName" class="form-control" required placeholder="Иван" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Фамилия <span class="text-danger">*</span></label>
                            <input type="text" name="LastName" class="form-control" required placeholder="Иванов" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Специализация <span class="text-danger">*</span></label>
                            <input type="text" name="Specialization" class="form-control" required placeholder="Обща ветеринарна медицина" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Телефон <span class="text-danger">*</span></label>
                            <input type="tel" name="Phone" class="form-control" required placeholder="+359 888 000 000" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Имейл <span class="text-danger">*</span></label>
                            <input type="email" name="Email" class="form-control" required placeholder="doktor@vetclinika.bg" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Биография</label>
                            <textarea name="Bio" class="form-control" rows="3" placeholder="Кратка биография на лекаря..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">URL на снимка</label>
                            <input type="url" name="ImageUrl" class="form-control" placeholder="https://example.com/photo.jpg" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" checked id="isActive" />
                                <label class="form-check-label" for="isActive">Активен лекар</label>
                            </div>
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази
                            </button>
                            <a asp-action="Veterinarians" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@using VeterinaryClinic.Services.DTOs
@model VetServiceDto
@{
    ViewData["Title"] = "Редактирай услуга";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>Редактирай услуга</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <a asp-action="Services" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="EditService" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Наименование <span class="text-danger">*</span></label>
                            <input type="text" name="Name" class="form-control" value="@Model.Name" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Описание</label>
                            <textarea name="Description" class="form-control" rows="3">@Model.Description</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Цена (лв.) <span class="text-danger">*</span></label>
                            <input type="number" name="Price" class="form-control" value="@Model.Price.ToString("F2")" required step="0.01" min="0" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Продължителност (мин.) <span class="text-danger">*</span></label>
                            <input type="number" name="DurationMinutes" class="form-control" value="@Model.DurationMinutes" required min="5" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActive" @(Model.IsActive ? "checked" : "") />
                                <label class="form-check-label" for="isActive">Активна услуга</label>
                            </div>
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази промените
                            </button>
                            <a asp-action="Services" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

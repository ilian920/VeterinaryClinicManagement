@using VeterinaryClinic.Services.DTOs
@{
    ViewData["Title"] = "Добави ваксинация";
    var animalId = ViewBag.AnimalId as int?;
    var vets = ViewBag.Veterinarians as IEnumerable<VeterinarianDto> ?? Enumerable.Empty<VeterinarianDto>();
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-syringe me-2"></i>Добави ваксинация</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <a asp-action="Index" asp-route-animalId="@animalId" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AnimalId" value="@animalId" />
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold">Наименование на ваксината <span class="text-danger">*</span></label>
                            <input type="text" name="VaccineName" class="form-control" required placeholder="Rabies, Distemper, ..." />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата на ваксинация <span class="text-danger">*</span></label>
                            <input type="date" name="VaccineDate" class="form-control" required
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Следваща доза</label>
                            <input type="date" name="NextDueDate" class="form-control"
                                   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ветеринарен лекар</label>
                            <select name="VeterinarianId" class="form-select">
                                <option value="">-- Изберете лекар --</option>
                                @foreach (var vet in vets)
                                {
                                    <option value="@vet.Id">Д-р @vet.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Партиден номер</label>
                            <input type="text" name="BatchNumber" class="form-control" placeholder="LOT-12345" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Бележки</label>
                            <textarea name="Notes" class="form-control" rows="2" placeholder="Допълнителна информация..."></textarea>
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази
                            </button>
                            <a asp-action="Index" asp-route-animalId="@animalId" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

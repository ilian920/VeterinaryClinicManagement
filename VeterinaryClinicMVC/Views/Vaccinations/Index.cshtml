@using VeterinaryClinic.Services.DTOs
@model IEnumerable<VaccinationDto>
@{
    ViewData["Title"] = "Ваксинации";
    var animalId = ViewBag.AnimalId as int?;
    var animalName = ViewBag.AnimalName as string;
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-syringe me-2"></i>Ваксинации</h1>
            @if (!string.IsNullOrEmpty(animalName)) { <p class="mb-0 opacity-75">За @animalName</p> }
        </div>
        @if (animalId.HasValue)
        {
            <a asp-action="Create" asp-route-animalId="@animalId" class="btn btn-light">
                <i class="bi bi-plus-circle me-2"></i>Добави ваксина
            </a>
        }
    </div>
</div>

<div class="container py-4">
    @if (animalId.HasValue)
    {
        <a asp-controller="Animals" asp-action="Details" asp-route-id="@animalId" class="btn btn-outline-secondary btn-sm mb-3">
            <i class="bi bi-arrow-left me-1"></i>Назад
        </a>
    }

    @if (Model.Any())
    {
        <div class="card">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Ваксина</th>
                            <th>Дата</th>
                            <th>Следваща доза</th>
                            <th>Партиден №</th>
                            <th>Лекар</th>
                            <th>Действия</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var vac in Model.OrderByDescending(v => v.VaccineDate))
                        {
                            var isOverdue = vac.NextDueDate.HasValue && vac.NextDueDate.Value < DateTime.Now;
                            <tr class="@(isOverdue ? "table-warning" : "")">
                                <td class="fw-bold">@vac.VaccineName</td>
                                <td>@vac.VaccineDate.ToString("dd.MM.yyyy")</td>
                                <td>
                                    @if (vac.NextDueDate.HasValue)
                                    {
                                        <span class="@(isOverdue ? "text-danger fw-bold" : "")">
                                            @vac.NextDueDate.Value.ToString("dd.MM.yyyy")
                                            @if (isOverdue) { <i class="bi bi-exclamation-triangle ms-1 text-danger"></i> }
                                        </span>
                                    }
                                    else { <span class="text-muted">—</span> }
                                </td>
                                <td class="small">@(vac.BatchNumber ?? "—")</td>
                                <td class="small">@(vac.VeterinarianName ?? "—")</td>
                                <td>
                                    <form asp-action="Delete" asp-route-id="@vac.Id" asp-route-animalId="@animalId" method="post" class="d-inline"
                                          onsubmit="return confirm('Изтриване на ваксинация @vac.VaccineName?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-syringe display-1 text-muted"></i>
            <p class="text-muted mt-3">Няма записани ваксинации</p>
            @if (animalId.HasValue)
            {
                <a asp-action="Create" asp-route-animalId="@animalId" class="btn btn-primary mt-2">
                    <i class="bi bi-plus-circle me-2"></i>Добави ваксина
                </a>
            }
        </div>
    }
</div>

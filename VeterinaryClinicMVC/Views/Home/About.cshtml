@{
    ViewData["Title"] = "За нас";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-info-circle me-2"></i>За нас</h1>
        <p class="mb-0 opacity-75">Научете повече за ВетКлиника</p>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card p-4 mb-4">
                <h3 class="text-success mb-3">Нашата история</h3>
                <p>ВетКлиника е основана с мисията да предоставя висококачествена ветеринарна грижа за домашни любимци в района на Димитровград. Нашият екип от опитни ветеринарни специалисти работи с любов и отдаденост всеки ден.</p>
                <p>Клиниката разполага с модерно оборудване и предлага широк спектър от услуги – от профилактични прегледи и ваксинации до хирургически интервенции и дентална грижа.</p>
                <p>Ние вярваме, че здравето на вашия любимец е от първостепенно значение. Затова предлагаме индивидуален подход към всеки пациент и неговия собственик.</p>
            </div>
            <div class="card p-4">
                <h3 class="text-success mb-3">Нашата мисия</h3>
                <p>Да осигурим най-добрата медицинска грижа за домашни любимци, съчетавайки съвременни технологии с топла и персонална грижа. Стремим се да бъдем надежден партньор за собствениците на животни и да допринасяме за здравето и щастието на техните любимци.</p>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card p-4 mb-3" style="background: #e8f5e9; border-left: 4px solid #2e7d32;">
                <h5 class="fw-bold text-success">Работно време</h5>
                <table class="table table-sm mb-0">
                    <tr><td>Пон – Пет</td><td class="text-end fw-bold">08:00 – 19:00</td></tr>
                    <tr><td>Събота</td><td class="text-end fw-bold">09:00 – 16:00</td></tr>
                    <tr><td>Неделя</td><td class="text-end fw-bold">10:00 – 14:00</td></tr>
                </table>
            </div>
            <div class="card p-4">
                <h5 class="fw-bold text-success">Контакти</h5>
                <p class="mb-1"><i class="bi bi-telephone me-2 text-success"></i>+359 888 123 456</p>
                <p class="mb-1"><i class="bi bi-envelope me-2 text-success"></i>info@vetclinika.bg</p>
                <p class="mb-0"><i class="bi bi-geo-alt me-2 text-success"></i>ул. Ветеринарна 1, Димитровград</p>
            </div>
        </div>
    </div>
</div>

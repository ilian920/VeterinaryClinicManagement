@{
    ViewData["Title"] = "Начало";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero Section -->
<section class="py-5" style="background: linear-gradient(135deg, #1b5e20 0%, #4caf50 100%); color: white; min-height: 480px; display: flex; align-items: center;">
    <div class="container text-center">
        <h1 class="display-4 fw-bold mb-3">
            <i class="bi bi-heart-pulse-fill me-3"></i>ВетКлиника
        </h1>
        <p class="lead mb-4">Вашата доверена ветеринарна клиника – грижа за вашите любимци с любов и експертиза</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Home" asp-action="BookAppointment" class="btn btn-light btn-lg px-4">
                <i class="bi bi-calendar-plus me-2"></i>Запишете час
            </a>
            <a asp-controller="Home" asp-action="Services" class="btn btn-outline-light btn-lg px-4">
                <i class="bi bi-grid me-2"></i>Нашите услуги
            </a>
        </div>
    </div>
</section>

<!-- Features Section -->
<section class="py-5">
    <div class="container">
        <h2 class="text-center mb-4 fw-bold">Защо да изберете нас?</h2>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 text-center p-4">
                    <div class="fs-1 text-success mb-3"><i class="bi bi-award"></i></div>
                    <h5 class="fw-bold">Опитен екип</h5>
                    <p class="text-muted">Нашите ветеринарни лекари имат дългогодишен опит и постоянно повишават квалификацията си.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 text-center p-4">
                    <div class="fs-1 text-success mb-3"><i class="bi bi-hospital"></i></div>
                    <h5 class="fw-bold">Модерно оборудване</h5>
                    <p class="text-muted">Разполагаме с най-съвременно медицинско оборудване за диагностика и лечение.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="card h-100 text-center p-4">
                    <div class="fs-1 text-success mb-3"><i class="bi bi-clock"></i></div>
                    <h5 class="fw-bold">Гъвкаво работно време</h5>
                    <p class="text-muted">Работим 7 дни в седмицата, за да можете да намерите удобно за вас време за преглед.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="py-5" style="background: #e8f5e9;">
    <div class="container text-center">
        <h2 class="fw-bold mb-3">Готови да се грижим за вашия любимец</h2>
        <p class="text-muted mb-4">Запишете час онлайн или се свържете с нас по телефона</p>
        <div class="d-flex gap-3 justify-content-center flex-wrap">
            <a asp-controller="Home" asp-action="BookAppointment" class="btn btn-success btn-lg px-4">
                <i class="bi bi-calendar-check me-2"></i>Запишете час
            </a>
            <a asp-controller="Home" asp-action="Contact" class="btn btn-outline-success btn-lg px-4">
                <i class="bi bi-telephone me-2"></i>Свържете се с нас
            </a>
        </div>
    </div>
</section>

<div class="text-center">
    <h1 class="display-4">Welcome</h1>
    <p>Learn about <a href="https://learn.microsoft.com/aspnet/core">building Web apps with ASP.NET Core</a>.</p>
</div>

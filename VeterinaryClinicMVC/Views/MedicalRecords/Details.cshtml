@using VeterinaryClinic.Services.DTOs
@model MedicalRecordDto
@{
    ViewData["Title"] = "Медицински запис";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-file-medical me-2"></i>Медицински запис</h1>
    </div>
</div>

<div class="container py-4">
    <a asp-action="Index" asp-route-animalId="@Model.AnimalId" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card p-4">
                <div class="d-flex justify-content-between mb-4">
                    <div>
                        <h4 class="fw-bold mb-0">@Model.Diagnosis</h4>
                        <small class="text-muted">@Model.AnimalName • @Model.RecordDate.ToString("dd.MM.yyyy")</small>
                    </div>
                    <div class="text-end">
                        <div class="text-muted small">Лекар</div>
                        <div class="fw-bold">@Model.VeterinarianName</div>
                    </div>
                </div>

                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded">
                            <div class="text-muted small fw-bold mb-1">Диагноза</div>
                            <div>@Model.Diagnosis</div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="p-3 bg-light rounded">
                            <div class="text-muted small fw-bold mb-1">Лечение</div>
                            <div>@Model.Treatment</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Prescription))
                    {
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <div class="text-muted small fw-bold mb-1">Предписания/Медикаменти</div>
                                <div>@Model.Prescription</div>
                            </div>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <div class="text-muted small fw-bold mb-1">Допълнителни бележки</div>
                                <div>@Model.Notes</div>
                            </div>
                        </div>
                    }
                    @if (Model.FollowUpDate.HasValue)
                    {
                        <div class="col-12">
                            <div class="alert alert-warning">
                                <i class="bi bi-calendar-event me-2"></i>
                                <strong>Следващ преглед:</strong> @Model.FollowUpDate.Value.ToString("dd MMMM yyyy")
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@using VeterinaryClinic.Services.DTOs
@{
    ViewData["Title"] = "Нов медицински запис";
    var animalId = ViewBag.AnimalId as int?;
    var vets = ViewBag.Veterinarians as IEnumerable<VeterinarianDto> ?? Enumerable.Empty<VeterinarianDto>();
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-file-medical-fill me-2"></i>Нов медицински запис</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Index" asp-route-animalId="@animalId" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="AnimalId" value="@animalId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ветеринарен лекар <span class="text-danger">*</span></label>
                            <select name="VeterinarianId" class="form-select" required>
                                <option value="">-- Изберете лекар --</option>
                                @foreach (var vet in vets)
                                {
                                    <option value="@vet.Id">Д-р @vet.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата на прегледа <span class="text-danger">*</span></label>
                            <input type="date" name="RecordDate" class="form-control" required
                                   value="@DateTime.Now.ToString("yyyy-MM-dd")"
                                   max="@DateTime.Now.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Диагноза <span class="text-danger">*</span></label>
                            <input type="text" name="Diagnosis" class="form-control" required placeholder="Въведете диагнозата..." />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Лечение <span class="text-danger">*</span></label>
                            <textarea name="Treatment" class="form-control" rows="3" required placeholder="Описание на лечението..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Предписания/Медикаменти</label>
                            <textarea name="Prescription" class="form-control" rows="2" placeholder="Предписани медикаменти и дозировка..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Допълнителни бележки</label>
                            <textarea name="Notes" class="form-control" rows="2" placeholder="Допълнителна информация..."></textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата за следващ преглед</label>
                            <input type="date" name="FollowUpDate" class="form-control"
                                   min="@DateTime.Now.AddDays(1).ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази запис
                            </button>
                            <a asp-action="Index" asp-route-animalId="@animalId" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

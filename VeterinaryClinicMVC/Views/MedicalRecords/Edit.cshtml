@using VeterinaryClinic.Services.DTOs
@model MedicalRecordDto
@{
    ViewData["Title"] = "Редактирай медицински запис";
    var vets = ViewBag.Veterinarians as IEnumerable<VeterinarianDto> ?? Enumerable.Empty<VeterinarianDto>();
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-pencil-square me-2"></i>Редактирай медицински запис</h1>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <a asp-action="Index" asp-route-animalId="@Model.AnimalId" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>
            <div class="card p-4">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="AnimalId" value="@Model.AnimalId" />
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Ветеринарен лекар <span class="text-danger">*</span></label>
                            <select name="VeterinarianId" class="form-select" required>
                                @foreach (var vet in vets)
                                {
                                    <option value="@vet.Id" selected="@(vet.Id == Model.VeterinarianId)">Д-р @vet.FullName</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата на прегледа <span class="text-danger">*</span></label>
                            <input type="date" name="RecordDate" class="form-control" required
                                   value="@Model.RecordDate.ToString("yyyy-MM-dd")" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Диагноза <span class="text-danger">*</span></label>
                            <input type="text" name="Diagnosis" class="form-control" value="@Model.Diagnosis" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Лечение <span class="text-danger">*</span></label>
                            <textarea name="Treatment" class="form-control" rows="3" required>@Model.Treatment</textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Предписания/Медикаменти</label>
                            <textarea name="Prescription" class="form-control" rows="2">@Model.Prescription</textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Допълнителни бележки</label>
                            <textarea name="Notes" class="form-control" rows="2">@Model.Notes</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Дата за следващ преглед</label>
                            <input type="date" name="FollowUpDate" class="form-control"
                                   value="@(Model.FollowUpDate?.ToString("yyyy-MM-dd"))" />
                        </div>
                        <div class="col-12 pt-2">
                            <button type="submit" class="btn btn-success px-4">
                                <i class="bi bi-check-circle me-2"></i>Запази промените
                            </button>
                            <a asp-action="Index" asp-route-animalId="@Model.AnimalId" class="btn btn-outline-secondary ms-2">Отказ</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

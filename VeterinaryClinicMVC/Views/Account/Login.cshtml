@{
    ViewData["Title"] = "Вход";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card p-4 shadow-sm">
                <div class="text-center mb-4">
                    <div class="rounded-circle bg-success d-inline-flex align-items-center justify-content-center mb-3" style="width:64px;height:64px;">
                        <i class="bi bi-person-fill text-white fs-3"></i>
                    </div>
                    <h3 class="fw-bold">Вход в системата</h3>
                    <p class="text-muted small">Въведете вашите данни за достъп</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger">
                        <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
                    </div>
                }

                <form asp-action="Login" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label class="form-label fw-bold">Потребителско име</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-person"></i></span>
                            <input type="text" name="username" class="form-control" placeholder="Въведете потребителско име" required autofocus />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label class="form-label fw-bold">Парола</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock"></i></span>
                            <input type="password" name="password" class="form-control" placeholder="Въведете парола" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-success w-100 py-2">
                        <i class="bi bi-box-arrow-in-right me-2"></i>Вход
                    </button>
                </form>

                <hr />
                <p class="text-center mb-0 small">
                    Нямате профил? <a asp-action="Register" class="text-success fw-bold">Регистрирайте се</a>
                </p>
            </div>

            <div class="text-center mt-3">
                <p class="small text-muted">
                    <strong>Тестови акаунти:</strong><br/>
                    Admin: <code>admin</code> / <code>Admin123!</code><br/>
                    Собственик: <code>owner1</code> / <code>Owner123!</code>
                </p>
            </div>
        </div>
    </div>
</div>

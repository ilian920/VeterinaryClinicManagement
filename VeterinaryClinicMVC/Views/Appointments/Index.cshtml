@using VeterinaryClinic.Services.DTOs
@using VeterinaryClinic.Shared.Enums
@model IEnumerable<AppointmentDto>
@{
    ViewData["Title"] = "Моите часове";
}

<div class="page-header">
    <div class="container d-flex justify-content-between align-items-center">
        <div>
            <h1 class="fw-bold mb-1"><i class="bi bi-calendar2-check me-2"></i>Моите часове</h1>
            <p class="mb-0 opacity-75">Всички записани прегледи</p>
        </div>
        <a asp-controller="Home" asp-action="BookAppointment" class="btn btn-light btn-lg">
            <i class="bi bi-plus-circle me-2"></i>Запиши нов час
        </a>
    </div>
</div>

<div class="container py-4">
    @if (Model.Any())
    {
        <div class="row g-3">
            @foreach (var appt in Model.OrderByDescending(a => a.AppointmentDate))
            {
                var cardClass = appt.Status switch {
                    AppointmentStatus.Completed => "border-success",
                    AppointmentStatus.Cancelled => "border-danger opacity-75",
                    _ => appt.AppointmentDate < DateTime.Now ? "border-warning" : ""
                };
                <div class="col-md-6">
                    <div class="card h-100 @cardClass">
                        <div class="card-body">
                            <div class="d-flex justify-content-between mb-2">
                                <div>
                                    <h6 class="fw-bold mb-0">@appt.AnimalName</h6>
                                    <small class="text-muted">Д-р @appt.VeterinarianName</small>
                                </div>
                                @{
                                    var badge = appt.Status switch {
                                        AppointmentStatus.Scheduled => "primary",
                                        AppointmentStatus.Completed => "success",
                                        AppointmentStatus.Cancelled => "danger",
                                        _ => "secondary"
                                    };
                                    var statusName = appt.Status switch {
                                        AppointmentStatus.Scheduled => "Предстои",
                                        AppointmentStatus.Completed => "Приключен",
                                        AppointmentStatus.Cancelled => "Отказан",
                                        _ => appt.Status.ToString()
                                    };
                                }
                                <span class="badge bg-@badge">@statusName</span>
                            </div>
                            <p class="mb-1">
                                <i class="bi bi-calendar3 me-2 text-muted"></i>
                                <strong>@appt.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</strong>
                            </p>
                            @if (appt.ServiceName != null)
                            {
                                <p class="mb-1 small">
                                    <i class="bi bi-grid me-2 text-muted"></i>@appt.ServiceName
                                    @if (appt.ServicePrice.HasValue) { <span class="text-success">(@appt.ServicePrice.Value.ToString("F2") лв.)</span> }
                                </p>
                            }
                            @if (!string.IsNullOrEmpty(appt.Notes))
                            {
                                <p class="small text-muted mb-0"><i class="bi bi-chat-text me-1"></i>@appt.Notes</p>
                            }
                        </div>
                        @if (appt.Status == AppointmentStatus.Scheduled)
                        {
                            <div class="card-footer bg-transparent">
                                <a asp-action="Details" asp-route-id="@appt.Id" class="btn btn-sm btn-outline-secondary me-1">Детайли</a>
                                <form asp-action="Cancel" asp-route-id="@appt.Id" method="post" class="d-inline"
                                      onsubmit="return confirm('Отказване на часа?')">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="bi bi-x-circle me-1"></i>Откажи
                                    </button>
                                </form>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar2 display-1 text-muted"></i>
            <h4 class="text-muted mt-3">Нямате записани часове</h4>
            <a asp-controller="Home" asp-action="BookAppointment" class="btn btn-success mt-3">
                <i class="bi bi-calendar-plus me-2"></i>Запишете първия си час
            </a>
        </div>
    }
</div>

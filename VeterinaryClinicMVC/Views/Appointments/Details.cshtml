@using VeterinaryClinic.Services.DTOs
@using VeterinaryClinic.Shared.Enums
@model AppointmentDto
@{
    ViewData["Title"] = "Детайли за час";
}

<div class="page-header">
    <div class="container">
        <h1 class="fw-bold"><i class="bi bi-calendar-event me-2"></i>Детайли за час</h1>
    </div>
</div>

<div class="container py-4">
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm mb-3"><i class="bi bi-arrow-left me-1"></i>Назад</a>

    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <h4 class="fw-bold mb-0">Преглед #@Model.Id</h4>
                    @{
                        var badge = Model.Status switch {
                            AppointmentStatus.Scheduled => "primary",
                            AppointmentStatus.Completed => "success",
                            AppointmentStatus.Cancelled => "danger",
                            _ => "secondary"
                        };
                        var statusName = Model.Status switch {
                            AppointmentStatus.Scheduled => "Предстои",
                            AppointmentStatus.Completed => "Приключен",
                            AppointmentStatus.Cancelled => "Отказан",
                            _ => Model.Status.ToString()
                        };
                    }
                    <span class="badge bg-@badge fs-6">@statusName</span>
                </div>

                <table class="table table-borderless">
                    <tr>
                        <td class="text-muted fw-bold" style="width:40%"><i class="bi bi-calendar3 me-2"></i>Дата и час:</td>
                        <td class="fw-bold fs-5">@Model.AppointmentDate.ToString("dd.MM.yyyy HH:mm")</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-bold"><i class="bi bi-badge-tm me-2"></i>Животно:</td>
                        <td>@Model.AnimalName</td>
                    </tr>
                    <tr>
                        <td class="text-muted fw-bold"><i class="bi bi-person-badge me-2"></i>Ветеринарен лекар:</td>
                        <td>Д-р @Model.VeterinarianName</td>
                    </tr>
                    @if (Model.ServiceName != null)
                    {
                        <tr>
                            <td class="text-muted fw-bold"><i class="bi bi-grid me-2"></i>Услуга:</td>
                            <td>
                                @Model.ServiceName
                                @if (Model.ServicePrice.HasValue)
                                {
                                    <span class="badge bg-success-subtle text-success ms-2">@Model.ServicePrice.Value.ToString("F2") лв.</span>
                                }
                            </td>
                        </tr>
                    }
                    @if (!string.IsNullOrEmpty(Model.Notes))
                    {
                        <tr>
                            <td class="text-muted fw-bold"><i class="bi bi-chat-text me-2"></i>Бележки:</td>
                            <td>@Model.Notes</td>
                        </tr>
                    }
                </table>

                @if (Model.Status == AppointmentStatus.Scheduled)
                {
                    <div class="border-top pt-3">
                        <form asp-action="Cancel" asp-route-id="@Model.Id" method="post" class="d-inline"
                              onsubmit="return confirm('Сигурни ли сте, че искате да откажете часа?')">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-danger">
                                <i class="bi bi-x-circle me-2"></i>Откажи часа
                            </button>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

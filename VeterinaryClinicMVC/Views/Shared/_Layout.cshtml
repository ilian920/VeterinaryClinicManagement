<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ВетКлиника</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        :root { --vet-green: #2e7d32; --vet-green-light: #4caf50; }
        .navbar-brand { font-weight: 700; color: var(--vet-green) !important; font-size: 1.4rem; }
        .navbar { background: #fff; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
        .nav-link { font-weight: 500; }
        .nav-link:hover { color: var(--vet-green) !important; }
        .btn-vet { background-color: var(--vet-green); color: #fff; border: none; }
        .btn-vet:hover { background-color: #1b5e20; color: #fff; }
        .footer-section { background: #1b5e20; color: #e8f5e9; padding: 2rem 0 1rem; margin-top: 3rem; }
        .footer-section a { color: #a5d6a7; text-decoration: none; }
        .footer-section a:hover { color: #fff; }
        .card { border: none; box-shadow: 0 2px 12px rgba(0,0,0,.07); border-radius: 12px; }
        .page-header { background: linear-gradient(135deg, #2e7d32 0%, #4caf50 100%); color: white; padding: 2rem 0; margin-bottom: 2rem; border-radius: 0 0 16px 16px; }
        .sidebar-nav .nav-link { color: #333; padding: .6rem 1rem; border-radius: 8px; }
        .sidebar-nav .nav-link:hover, .sidebar-nav .nav-link.active { background: #e8f5e9; color: var(--vet-green); }
        .table th { background: #f5f5f5; }
        .badge-scheduled { background: #1976d2; }
        .badge-completed { background: #2e7d32; }
        .badge-cancelled { background: #d32f2f; }
    </style>
</head>
<body class="bg-light">
    <nav class="navbar navbar-expand-lg sticky-top">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-heart-pulse-fill text-success me-2"></i>ВетКлиника
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMain">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navMain">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Начало</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">За нас</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Team">Нашият екип</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Services">Услуги</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Контакти</a></li>
                    @if (ViewBag.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="BookAppointment">Запишете час</a></li>
                        @if (ViewBag.CurrentUserRole?.ToString() == "Owner")
                        {
                            <li class="nav-item"><a class="nav-link" asp-controller="Animals" asp-action="Index">Моите животни</a></li>
                            <li class="nav-item"><a class="nav-link" asp-controller="Appointments" asp-action="Index">Часове</a></li>
                        }
                        @if (ViewBag.CurrentUserRole?.ToString() == "Admin")
                        {
                            <li class="nav-item"><a class="nav-link fw-bold text-success" asp-controller="Admin" asp-action="Dashboard">Админ панел</a></li>
                        }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (ViewBag.IsAuthenticated == true)
                    {
                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle" href="#" data-bs-toggle="dropdown">
                                <i class="bi bi-person-circle me-1"></i>@ViewBag.CurrentUsername
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="bi bi-person me-2"></i>Профил</a></li>
                                <li><hr class="dropdown-divider" /></li>
                                <li><a class="dropdown-item text-danger" asp-controller="Account" asp-action="Logout"><i class="bi bi-box-arrow-right me-2"></i>Изход</a></li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login">Вход</a></li>
                        <li class="nav-item"><a class="btn btn-vet ms-2" asp-controller="Account" asp-action="Register">Регистрация</a></li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @if (TempData["Success"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="container mt-3">
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer-section">
        <div class="container">
            <div class="row">
                <div class="col-md-4 mb-3">
                    <h5><i class="bi bi-heart-pulse-fill me-2"></i>ВетКлиника</h5>
                    <p class="small">Грижа за вашите любимци с любов и професионализъм.</p>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Бързи връзки</h6>
                    <ul class="list-unstyled small">
                        <li><a asp-controller="Home" asp-action="About">За нас</a></li>
                        <li><a asp-controller="Home" asp-action="Services">Услуги</a></li>
                        <li><a asp-controller="Home" asp-action="Team">Нашият екип</a></li>
                        <li><a asp-controller="Home" asp-action="Contact">Контакти</a></li>
                    </ul>
                </div>
                <div class="col-md-4 mb-3">
                    <h6>Контакти</h6>
                    <p class="small mb-1"><i class="bi bi-telephone me-2"></i>+359 888 123 456</p>
                    <p class="small mb-1"><i class="bi bi-envelope me-2"></i>info@vetclinika.bg</p>
                    <p class="small"><i class="bi bi-geo-alt me-2"></i>ул. Ветеринарна 1, Димитровград</p>
                </div>
            </div>
            <hr style="border-color: #4caf50;" />
            <p class="text-center small mb-0">&copy; 2026 ВетКлиника. Всички права запазени.</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
